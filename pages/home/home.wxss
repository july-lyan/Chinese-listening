/* home.wxss */
.home-container {
  padding: 2.5rem 1.5rem;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  text-align: center;
  margin-bottom: 3rem;
  animation: fadeIn 0.8s ease-out;
}

.title {
  font-size: 2.2rem;
  font-weight: bold;
  color: #FF8C00;
  margin-bottom: 1rem;
  text-shadow: 0 2px 4px rgba(255, 179, 71, 0.2);
  animation: fadeInDown 0.8s ease-out;
}

.subtitle {
  font-size: 1.3rem;
  color: #8D6E63;
  animation: fadeIn 0.8s ease-out 0.2s both;
}

.difficulty-container {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  width: 100%;
  max-width: 400px;
}

.difficulty-card {
  background-color: #FFFFFF;
  border-radius: 12px;
  padding: 2rem;
  box-shadow: 0 4px 12px rgba(255, 179, 71, 0.15);
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.8s ease-out;
}

.difficulty-card:nth-child(2) {
  animation-delay: 0.2s;
}

.difficulty-card:nth-child(3) {
  animation-delay: 0.4s;
}

.difficulty-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4px;
  transition: all 0.3s ease;
}

.difficulty-card.easy::before {
  background: linear-gradient(90deg, #FFB347, #66BB6A);
}

.difficulty-card.medium::before {
  background: linear-gradient(90deg, #FFB347, #FF8C00);
}

.difficulty-card.hard::before {
  background: linear-gradient(90deg, #FF8C00, #EF5350);
}

.difficulty-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.difficulty-title {
  font-size: 1.5rem;
  font-weight: bold;
  color: #5D4037;
}

.difficulty-badge {
  padding: 0.4rem 1rem;
  border-radius: 25px;
  font-size: 0.9rem;
  font-weight: bold;
  transition: all 0.3s ease;
}

.difficulty-card.easy .difficulty-badge {
  background-color: rgba(102, 187, 106, 0.1);
  color: #66BB6A;
}

.difficulty-card.medium .difficulty-badge {
  background-color: rgba(255, 140, 0, 0.1);
  color: #FF8C00;
}

.difficulty-card.hard .difficulty-badge {
  background-color: rgba(239, 83, 80, 0.1);
  color: #EF5350;
}

.difficulty-subtitle {
  font-size: 1rem;
  color: #8D6E63;
  margin-bottom: 1.5rem;
  font-weight: 500;
}

.difficulty-description {
  font-size: 1rem;
  line-height: 1.6;
  color: #8D6E63;
  margin-bottom: 2rem;
}

.difficulty-button {
  width: 100%;
  padding: 1rem;
  font-size: 1.1rem;
  border-radius: 12px;
  border: none;
  font-weight: 500;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.difficulty-card.easy .difficulty-button {
  background: linear-gradient(135deg, #66BB6A, #4CAF50);
  color: white;
}

.difficulty-card.medium .difficulty-button {
  background: linear-gradient(135deg, #FF8C00, #FFB347);
  color: white;
}

.difficulty-card.hard .difficulty-button {
  background: linear-gradient(135deg, #EF5350, #D32F2F);
  color: white;
}

/* 动画效果 */
@keyframes fadeIn {
  from { 
    opacity: 0; 
    transform: translateY(20px); 
  }
  to { 
    opacity: 1; 
    transform: translateY(0); 
  }
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 响应式布局 */
@media (max-width: 768px) {
  .home-container {
    padding: 2rem 1rem;
  }
  
  .title {
    font-size: 2rem;
  }
  
  .subtitle {
    font-size: 1.2rem;
  }
  
  .difficulty-card {
    padding: 1.8rem;
  }
}

@media (max-width: 480px) {
  .home-container {
    padding: 1.5rem 1rem;
  }
  
  .title {
    font-size: 1.8rem;
  }
  
  .subtitle {
    font-size: 1.1rem;
  }
  
  .difficulty-card {
    padding: 1.5rem;
  }
  
  .difficulty-title {
    font-size: 1.3rem;
  }
  
  .difficulty-description {
    font-size: 0.9rem;
  }
}